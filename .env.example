# Public Firebase Web configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only Firebase Admin credentials. Prefer one encrypted JSON variable on Vercel.
FIREBASE_ADMIN_SERVICE_ACCOUNT=

# Alternative split server-only credentials:
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Private Vercel Blob (normally injected by the linked Blob store)
BLOB_READ_WRITE_TOKEN=

# Optional Google Translate (existing site feature)
# GOOGLE_TRANSLATE_API_KEY=

# ---- AI Travel Assistant (server-only; never NEXT_PUBLIC_*) ----
OPENAI_API_KEY=
OPENAI_VECTOR_STORE_ID=
OPENAI_RESPONSE_MODEL=gpt-4.1-mini
OPENAI_MAX_SEARCH_RESULTS=8
OPENAI_MIN_RELEVANCE_SCORE=0.35
AI_ASSISTANT_MAX_INPUT_LENGTH=1000
AI_ASSISTANT_RATE_LIMIT_PER_10_MINUTES=20
AI_ASSISTANT_ANON_RATE_LIMIT_PER_10_MINUTES=8
AI_ASSISTANT_REQUEST_TIMEOUT_MS=45000
# Comma-separated admin allow-list for /admin/unanswered-questions
AI_ADMIN_UIDS=
AI_ADMIN_EMAILS=

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Point balances, reward markers and unlocks are authoritative server data.
    // The Admin SDK bypasses these rules; browser and REST clients never write.
    match /users/{uid} {
      allow get: if isOwner(uid);
      allow list: if false;
      allow create, update, delete: if false;

      match /ledger/{entryId} {
        allow get, list: if isOwner(uid);
        allow create, update, delete: if false;
      }
    }

    // Forum content is read and written only through authenticated server APIs.
    // This prevents clients from forging authors, timestamps, or counters.
    match /forumPosts/{postId} {
      allow read, write: if false;
    }

    match /forumComments/{postId}/entries/{commentId} {
      allow read, write: if false;
    }

    match /forumPostStats/{postId} {
      allow read, write: if false;
    }

    match /forumRateLimits/{uid} {
      allow read, write: if false;
    }

    match /forumLikes/{likeId} {
      allow read, write: if false;
    }

    match /forumNotifications/{notificationId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
